# Generated by Cargo
# will have compiled files and executables
/target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# FLUX logs
log/

.vscode/

.liquid

# Generated Lean project: regenerated by `cargo flux` + runlean.sh.
# Source of truth for proofs is LeanUserProofs/ (savelean.sh copies them back).
lean_proofs/

# Lake build artifacts. LeanUserProofs/ is a source store, not built in place —
# the editor may still generate these when it opens the folder; never commit them.
.lake/
LeanUserProofs/lake-manifest.json

# Local editor / agent config
.claude/